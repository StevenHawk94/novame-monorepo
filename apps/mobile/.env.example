# @novame/mobile environment variables
#
# Copy this file to .env.local and fill in the actual values.
#   cp apps/mobile/.env.example apps/mobile/.env.local
#
# .env.local is gitignored. Never commit it.
#
# All EXPO_PUBLIC_* values are baked into the app bundle and visible
# to anyone who downloads the app — only put values here that are
# safe to be public (anon keys, public API URLs).
#
# Server-only secrets (SUPABASE_SERVICE_ROLE_KEY, AIRWALLEX_API_KEY,
# RESEND_API_KEY, etc.) belong in apps/api environment, NOT here.

# Supabase project URL — same as admin/api NEXT_PUBLIC_SUPABASE_URL
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key — same as admin/api NEXT_PUBLIC_SUPABASE_ANON_KEY
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# NovaMe API base URL
#   Local development: http://localhost:3001
#   Production:        https://novame-monorepo-api.vercel.app
EXPO_PUBLIC_API_URL=
