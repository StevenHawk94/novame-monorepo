# ──────────────────────────────────────────────
# Supabase (REQUIRED)
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ──────────────────────────────────────────────
# AI providers (REQUIRED)
# ──────────────────────────────────────────────
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# ──────────────────────────────────────────────
# Apple In-App Purchase (REQUIRED for iOS)
# ──────────────────────────────────────────────
APPLE_SHARED_SECRET=

# ──────────────────────────────────────────────
# Google Play Billing (REQUIRED for Android)
# ──────────────────────────────────────────────
GOOGLE_PLAY_SERVICE_ACCOUNT=
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# ──────────────────────────────────────────────
# Google Cloud Vision (used in admin OCR / analysis)
# ──────────────────────────────────────────────
GOOGLE_CLOUD_VISION_API_KEY=

# ──────────────────────────────────────────────
# Airwallex Payment (REQUIRED for book/card orders)
# ──────────────────────────────────────────────
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=
AIRWALLEX_ENV=demo
PAYMENT_MODE=test

# ──────────────────────────────────────────────
# Cloudflare R2 (object storage, S3-compatible)
# ──────────────────────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=

# ──────────────────────────────────────────────
# Email (Resend — for support tickets etc.)
# ──────────────────────────────────────────────
RESEND_API_KEY=

# ──────────────────────────────────────────────
# Public URLs
# ──────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://api.soulsayit.com
NEXT_PUBLIC_APP_URL=https://novame.app
