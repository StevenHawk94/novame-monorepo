# Copy this file to .env.local and fill in real values.
# .env.local is gitignored; this example file is committed for onboarding.

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----- Admin access -----
# Comma-separated list of email addresses allowed to log in to admin
ADMIN_EMAILS=admin@example.com,owner@example.com

# ----- Cross-app API proxy -----
# next.config.js rewrites /api/orders, /api/force-update, /api/generate-abc-cards
# to this URL (apps/api). Use http://localhost:3001 in local dev when running api side-by-side.
NOVAME_API_URL=https://novame-monorepo-api.vercel.app
