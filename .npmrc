# Hoist React Native peer deps so Metro can resolve them
public-hoist-pattern[]=*react-native*
public-hoist-pattern[]=*expo*
public-hoist-pattern[]=*@react-native*
public-hoist-pattern[]=*@expo*

# Strict peer deps off (RN ecosystem has many peer-dep mismatches)
strict-peer-dependencies=false

# Auto-install peers (avoid manual peer-dep babysitting)
auto-install-peers=true

# Use shamefully-hoist for Metro bundler compatibility
shamefully-hoist=true
